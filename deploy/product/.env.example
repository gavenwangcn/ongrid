# ==============================================================================
# ongrid 生产环境 .env — deploy/product/
#
# 首次部署（解压 build-product-deploy-bundle.sh 产物后）：
#   sudo tar -xzvf ongrid-product-deploy-*.tar.gz -C /opt/ongrid
#   cd /opt/ongrid/deploy/product && cp .env.example .env
#   编辑 ONGRID_DEPLOY_ROOT、镜像、密码、对外地址
#   ./bootstrap-data-dirs.sh
#
# 运维命令见 docker-compose-deploy.yml 文件头；常用如下（cd deploy/product）：
#
# 启动全栈：
#   docker compose -f docker-compose-deploy.yml --env-file .env up -d
#
# 发版（仅 ongrid + nginx，源码构建镜像）：
#   docker compose -f docker-compose-deploy.yml --env-file .env pull ongrid nginx
#   docker compose -f docker-compose-deploy.yml --env-file .env up -d --no-deps ongrid
#   docker compose -f docker-compose-deploy.yml --env-file .env up -d --no-deps nginx
#
# 仅重启应用（不换镜像）：
#   docker compose -f docker-compose-deploy.yml --env-file .env restart ongrid nginx
# ==============================================================================

# ------------------------------------------------------------------------------
# 部署根目录（解压后的 deploy/ 路径，compose 挂载配置文件的基准）
# ------------------------------------------------------------------------------
# 示例：tar -xzvf bundle.tar.gz -C /opt/ongrid  →  /opt/ongrid/deploy/
ONGRID_DEPLOY_ROOT=/opt/ongrid/deploy

# ------------------------------------------------------------------------------
# 镜像（构建机 build 后 tag/push，生产机填写完整镜像引用）
# ------------------------------------------------------------------------------
# 构建机示例：
#   docker compose -f deploy/docker-compose.yml build
#   export VER=v0.8.4
#   docker tag ongrid:${VER} <registry>/ongrid:${VER}
#   docker tag ongrid-web:${VER} <registry>/ongrid-web:${VER}
#   docker push <registry>/ongrid:${VER}
#   docker push <registry>/ongrid-web:${VER}
ONGRID_VERSION=v0.8.4
ONGRID_IMAGE=<registry>/ongrid:v0.8.4
ONGRID_WEB_IMAGE=<registry>/ongrid-web:v0.8.4

# 第三方基础镜像（一般无需改动，可按需覆盖为私有镜像）
MYSQL_IMAGE=mysql:8.0
FRONTIER_IMAGE=singchia/frontier:1.2.5
PROMETHEUS_IMAGE=prom/prometheus:v2.54.0
LOKI_IMAGE=grafana/loki:3.4.0
TEMPO_IMAGE=grafana/tempo:2.5.0
QDRANT_IMAGE=qdrant/qdrant:v1.11.3
GRAFANA_IMAGE=grafana/grafana-oss:11.1.4
SEARXNG_IMAGE=searxng/searxng:latest

# ------------------------------------------------------------------------------
# 对外访问（HTTP，非 80/443）
# ------------------------------------------------------------------------------
# 管理端 Web UI + API + Grafana 嵌入入口（nginx 容器内 80 → 主机端口）
ONGRID_HTTP_PORT=30088
# Prometheus 直连（PromQL / 运维），容器内 9090 → 主机端口
PROM_EXTERNAL_PORT=30091
# Edge 隧道 broker 对外端口
ONGRID_TUNNEL_PORT=40012
# Manager metrics（主机 Prometheus 可 scrape）
ONGRID_METRICS_PORT=9100

# 公网/内网访问主机（无协议、无路径）
ONGRID_PUBLIC_HOST=156.254.6.224

# Edge 数据面上报地址（必须含 HTTP 端口，供 promtail/otel 推送到 nginx）
ONGRID_PUBLIC_URL=http://156.254.6.224:30088

# Grafana 对外根 URL（必须含端口 + /grafana/ 尾斜杠，与 nginx 子路径一致）
ONGRID_GRAFANA_ROOT_URL=http://156.254.6.224:30088/grafana/

# ------------------------------------------------------------------------------
# 数据目录与运行时内容根
# ------------------------------------------------------------------------------
ONGRID_DATA_DIR=/var/lib/ongrid
ONGRID_LOG_DIR=/var/log/ongrid

# 知识库 git clone 目录（bootstrap 会将包内 knowledge/builtin_vault 同步到此处）
ONGRID_KNOWLEDGE_REPO_DIR=/var/lib/ongrid/repos
# marketplace 可写 skill 安装目录
ONGRID_SKILLS_ROOT=/var/lib/ongrid/skills
# 内置 skill/agent（只读，由包内 product/runtime/ 挂载到容器 /skills /agents）
ONGRID_BUILTIN_SKILLS_ROOT=/skills
ONGRID_BUILTIN_AGENTS_ROOT=/agents

# 首次部署执行 ./bootstrap-data-dirs.sh（创建目录、同步 vault/嵌入模型、chown）。
# 配置/看板/告警规则/edge/知识库/skills/agents 均由 build-product-deploy-bundle.sh 打入包内。

# ------------------------------------------------------------------------------
# MySQL（生产必须修改密码）
# ------------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me-mysql-root
MYSQL_PASSWORD=change-me-mysql-ongrid

# ------------------------------------------------------------------------------
# Grafana 管理员（manager 首次启动用于创建 Service Account token）
# ------------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin
ONGRID_GRAFANA_INTERNAL_URL=http://grafana:3000/grafana
ONGRID_GRAFANA_TLS_INSECURE=false
ONGRID_LOG_URL=http://loki:3100
ONGRID_TRACE_QUERY_URL=http://tempo:3200

# ------------------------------------------------------------------------------
# JWT / 引导管理员
# ------------------------------------------------------------------------------
ONGRID_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ONGRID_JWT_ACCESS_TTL=15m
ONGRID_JWT_REFRESH_TTL=720h
ONGRID_ADMIN_EMAIL=admin@ongrid.local
ONGRID_ADMIN_PASSWORD=change-me-on-first-login

# ------------------------------------------------------------------------------
# 服务监听（容器内，一般不改）
# ------------------------------------------------------------------------------
ONGRID_HTTP_ADDR=:8080
ONGRID_METRICS_ADDR=:9100

# ------------------------------------------------------------------------------
# Frontier broker（ADR-007）
# ------------------------------------------------------------------------------
ONGRID_FRONTIER_ADDR=frontier:40011
ONGRID_FRONTIER_SERVICE_NAME=ongrid-manager

# ------------------------------------------------------------------------------
# OpenAI / 多厂商 LLM（留空则禁用对应能力）
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
ONGRID_ZHIPU_API_KEY=
ONGRID_ZHIPU_MODEL=
ONGRID_ZHIPU_BASE_URL=
ONGRID_ANTHROPIC_API_KEY=
ONGRID_ANTHROPIC_MODEL=
ONGRID_ANTHROPIC_BASE_URL=
ONGRID_GEMINI_API_KEY=
ONGRID_GEMINI_MODEL=
ONGRID_DEEPSEEK_API_KEY=
ONGRID_DEEPSEEK_MODEL=
ONGRID_KIMI_API_KEY=
ONGRID_KIMI_MODEL=
ONGRID_LLM_DEFAULT_PROVIDER=

# LLM 采样参数（留空则不向 API 传递，使用厂商默认）
# ONGRID_LLM_TEMPERATURE=0.1
# ONGRID_LLM_TOP_P=0.9
# ONGRID_LLM_MAX_TOKENS=4096
# ONGRID_LLM_FREQUENCY_PENALTY=0
# ONGRID_LLM_PRESENCE_PENALTY=0
ONGRID_LLM_DAILY_TOKEN_LIMIT=0

# ------------------------------------------------------------------------------
# AIOps / Agent
# ------------------------------------------------------------------------------
ONGRID_INVESTIGATOR_ENABLED=true
ONGRID_INVESTIGATOR_MIN_SEVERITY=warning
ONGRID_AGENT_KERNEL=graph
ONGRID_TOOLBAG_DEFERRAL_THRESHOLD=30

# ------------------------------------------------------------------------------
# 知识库 / RAG 嵌入
# ------------------------------------------------------------------------------
# local =  bundled BGE ONNX（需将模型放到 ONGRID_DATA_DIR/embeddings/）
ONGRID_EMBEDDING_PROVIDER=local
ONGRID_EMBEDDING_MODEL=bge-small-zh-v1.5
ONGRID_EMBEDDING_DIM=512
ONGRID_EMBEDDING_API_KEY=
ONGRID_EMBEDDING_BASE_URL=
ONGRID_EMBEDDING_CACHE_DIR=/var/lib/ongrid/embeddings
ONGRID_QDRANT_URL=http://qdrant:6333

# ------------------------------------------------------------------------------
# 链路追踪（OTel → Tempo）
# ------------------------------------------------------------------------------
ONGRID_OTEL_ENDPOINT=tempo:4318

# ------------------------------------------------------------------------------
# 云侧 Prometheus（ADR-009）
# ------------------------------------------------------------------------------
ONGRID_PROM_ENABLED=true
ONGRID_PROM_URL=http://prometheus:9090/prometheus
ONGRID_PROM_REMOTE_WRITE_URL=
ONGRID_PROM_QUERY_URL=http://prometheus:9090/prometheus
ONGRID_PROM_TLS_INSECURE=false
ONGRID_PROM_TLS_CA_FILE=

# ------------------------------------------------------------------------------
# 内置主机告警阈值
# ------------------------------------------------------------------------------
ONGRID_ALERT_ENABLED=true
ONGRID_ALERT_COOLDOWN=10m
ONGRID_ALERT_EVAL_INTERVAL=
ONGRID_ALERT_CPU_PERCENT=90
ONGRID_ALERT_MEM_PERCENT=90
ONGRID_ALERT_DISK_USED_PERCENT=90
ONGRID_ALERT_LOAD1=0

# ------------------------------------------------------------------------------
# 出站通知
# ------------------------------------------------------------------------------
ONGRID_NOTIFY_ENABLED=false
ONGRID_NOTIFY_DEFAULT_CHANNELS=log
ONGRID_NOTIFY_TIMEOUT=10s
ONGRID_NOTIFY_LOG_ENABLED=true
ONGRID_NOTIFY_LOG_NAME=log
ONGRID_NOTIFY_WEBHOOK_ENABLED=false
ONGRID_NOTIFY_WEBHOOK_NAME=webhook
ONGRID_NOTIFY_WEBHOOK_URL=
ONGRID_NOTIFY_WEBHOOK_SECRET=
ONGRID_NOTIFY_SLACK_ENABLED=false
ONGRID_NOTIFY_SLACK_NAME=slack
ONGRID_NOTIFY_SLACK_WEBHOOK_URL=
ONGRID_NOTIFY_FEISHU_ENABLED=false
ONGRID_NOTIFY_FEISHU_NAME=feishu
ONGRID_NOTIFY_FEISHU_WEBHOOK_URL=
ONGRID_NOTIFY_FEISHU_SECRET=
ONGRID_NOTIFY_DINGTALK_ENABLED=false
ONGRID_NOTIFY_DINGTALK_NAME=dingtalk
ONGRID_NOTIFY_DINGTALK_WEBHOOK_URL=
ONGRID_NOTIFY_DINGTALK_SECRET=

# ------------------------------------------------------------------------------
# Edge 安装参考（edge 主机上执行，非 compose 变量）
# ------------------------------------------------------------------------------
# 在线安装：
#   curl -sSL http://156.254.6.224:30088/install.sh | bash -s -- \
#     --access-key=<key> --secret-key=<secret> \
#     --server-edge-addr=156.254.6.224:40012 \
#     --server-http-addr=156.254.6.224:30088
#
# 构建 web 镜像时（构建机 deploy/.env）建议：
#   VITE_EDGE_INSTALL_SCHEME=http
