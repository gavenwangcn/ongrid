# ongrid — local dev compose (deploy/docker-compose.yml)
#
# Copy to deploy/.env and adjust. Every value below has a sane default in the
# compose file, so the stack also boots with no .env at all — this file just
# covers the handful you'll usually want to set for local development.
#
# This is a LOCAL DEV convenience stack: no TLS, trivial DB password baked into
# the compose file. Do NOT expose it beyond localhost. For production use the
# release package under deploy/install/ instead.

# --- First admin (seeded on first boot; if empty, no admin is created) ---
ONGRID_ADMIN_EMAIL=admin@ongrid.local
ONGRID_ADMIN_PASSWORD=change-me

# --- JWT signing secret (override the insecure default) ---
ONGRID_JWT_SECRET=change-me-to-a-long-random-string

# --- LLM endpoint (any OpenAI-compatible API; empty key => AI chat is disabled) ---
ONGRID_OPENAI_API_KEY=
ONGRID_OPENAI_MODEL=gpt-4o
# ONGRID_OPENAI_BASE_URL=https://api.openai.com/v1

# LLM sampling (agent + graph chat). Leave blank to omit each parameter.
# ONGRID_LLM_TEMPERATURE=0.1
# ONGRID_LLM_TOP_P=0.9
# ONGRID_LLM_MAX_TOKENS=4096
# ONGRID_LLM_FREQUENCY_PENALTY=0
# ONGRID_LLM_PRESENCE_PENALTY=0

# --- Embedded Grafana (local dev defaults; production install generates random) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# ONGRID_GRAFANA_INTERNAL_URL=http://grafana:3000/grafana
# Leave empty to disable embedded Grafana token bootstrap.
# ONGRID_GRAFANA_BOOTSTRAP_PASSWORD=

# --- Public URL edges use for logs/traces push (must match browser scheme) ---
# HTTP internal example: http://156.254.6.224
# HTTPS production:       https://ops.example.com
ONGRID_PUBLIC_URL=http://127.0.0.1

# --- Devices UI: edge install one-liner scheme (http | https | empty=auto) ---
VITE_EDGE_INSTALL_SCHEME=http

# --- Embedding provider for knowledge base / RAG ---
ONGRID_EMBEDDING_PROVIDER=local
ONGRID_EMBEDDING_MODEL=bge-small-zh-v1.5
ONGRID_EMBEDDING_DIM=512
ONGRID_EMBEDDING_API_KEY=
ONGRID_EMBEDDING_BASE_URL=
