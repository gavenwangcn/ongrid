# ongrid-web image — multi-stage. Stage 1 builds the SPA from web/, stage 2
# bakes the built assets into nginx. nginx.conf and TLS certs are bind-mounted
# at runtime by docker-compose, so operators can edit them without rebuilding.
# Build context MUST be the repo root (Dockerfile lives in deploy/, but it
# COPYs `web/` from the root).

ARG VERSION=dev

# ---------- Stage 1: build the SPA ----------
FROM node:20-alpine AS builder

ARG VERSION
# Force http/https in the Devices install one-liner. Empty = follow browser protocol.
ARG VITE_EDGE_INSTALL_SCHEME=
ENV VITE_EDGE_INSTALL_SCHEME=$VITE_EDGE_INSTALL_SCHEME
WORKDIR /app

# Cache dependency install layer separately from the source tree.
COPY web/package.json web/package-lock.json* ./
RUN npm ci --prefer-offline

COPY web/ ./
RUN npm run build

# ---------- Stage 2: nginx + static assets ----------
FROM nginx:1.27-alpine

# Built SPA assets shipped inside the image so it can serve standalone if
# operators forget the bind-mount (ADR-008).
COPY --from=builder /app/dist/ /usr/share/nginx/html/

# Default fallback config — overridden by docker-compose bind-mount in
# production. Lets the image run as a smoke test image without extra files.
COPY deploy/nginx/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80 443
