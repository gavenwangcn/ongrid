# Database (default: MySQL)
ONGRID_DB_DIALECT=mysql
ONGRID_DB_DSN=ongrid:ongrid@tcp(127.0.0.1:3306)/ongrid?parseTime=true&charset=utf8mb4&loc=Local

# For SQLite (opt-in, suitable for single-user local dev):
# ONGRID_DB_DIALECT=sqlite
# ONGRID_DB_PATH=./data/ongrid.db

# Server ports (in-container; nginx fronts these on the host — see ADR-008)
ONGRID_HTTP_ADDR=:8080
ONGRID_METRICS_ADDR=:9100

# Application log level (JSON stderr): debug | info | warn | error
# Default info. Use debug to see gorm record-not-found and other debug logs.
# ONGRID_LOG_LEVEL=info

# nginx-fronted host ports (ADR-008). 443 = HTTPS, 80 = HTTP redirect.
# Set ONGRID_HTTP_REDIRECT_PORT=0 to disable the 80 -> 443 redirect.
ONGRID_HTTP_PORT=443
ONGRID_HTTP_REDIRECT_PORT=80

# --- Frontier broker (upstream singchia/frontier; ADR-007) ---
# Manager dials the broker's service-bound port (40011). Inside docker
# compose use `frontier:40011`; for `make run-ongrid` against a frontier
# container exposed via the dev compose, use `localhost:40011`.
ONGRID_FRONTIER_ADDR=frontier:40011
ONGRID_FRONTIER_SERVICE_NAME=ongrid-manager

# Bootstrap admin (cloud only). Seeded on first startup if the email is
# unused. Leave both empty to start with an empty users table (nobody can
# log in until you set these and restart).
ONGRID_ADMIN_EMAIL=admin@ongrid.local
ONGRID_ADMIN_PASSWORD=change-me-on-first-login

# JWT signing
ONGRID_JWT_SECRET=change-me-to-a-long-random-string
ONGRID_JWT_ACCESS_TTL=15m
ONGRID_JWT_REFRESH_TTL=168h

# OpenAI
ONGRID_OPENAI_API_KEY=
ONGRID_OPENAI_MODEL=gpt-4o
ONGRID_OPENAI_BASE_URL=

# LLM sampling (agent + graph chat). Leave blank to omit each parameter
# and let the provider use its own defaults.
# ONGRID_LLM_TEMPERATURE=0.1
# ONGRID_LLM_TOP_P=0.9
# ONGRID_LLM_MAX_TOKENS=4096
# ONGRID_LLM_FREQUENCY_PENALTY=0
# ONGRID_LLM_PRESENCE_PENALTY=0

# --- Cloud-side Prometheus (ADR-009) ---
# When ONGRID_PROM_ENABLED=true the manager forwards push_prom_samples to
# remote_write, and the AI agent gains a query_promql tool. Leave false
# until you actually deploy a Prom container.
ONGRID_PROM_ENABLED=true
ONGRID_PROM_URL=http://prometheus:9090/prometheus
# Optional exact remote_write endpoint for Prometheus-compatible TSDBs
# (VictoriaMetrics / Mimir / Cortex / Thanos receive). Empty means
# ONGRID_PROM_URL + /api/v1/write.
ONGRID_PROM_REMOTE_WRITE_URL=
# Optional Prometheus-compatible query API root. Empty means ONGRID_PROM_URL.
ONGRID_PROM_QUERY_URL=http://prometheus:9090/prometheus

# --- Built-in host alert thresholds (fast-path HostMetricPoint) ---
ONGRID_ALERT_ENABLED=true
ONGRID_ALERT_COOLDOWN=10m
ONGRID_ALERT_CPU_PERCENT=90
ONGRID_ALERT_MEM_PERCENT=90
ONGRID_ALERT_DISK_USED_PERCENT=90
# 0 disables load1 alerting; set an absolute load threshold if desired.
ONGRID_ALERT_LOAD1=0

# --- Outbound notifications (alerts / scheduled jobs / proactive AIOps) ---
# Disabled by default. Set default channels to any enabled channel names below.
ONGRID_NOTIFY_ENABLED=false
ONGRID_NOTIFY_DEFAULT_CHANNELS=log
ONGRID_NOTIFY_TIMEOUT=10s

# Local dry-run sink. Useful before wiring real external channels.
ONGRID_NOTIFY_LOG_ENABLED=true
ONGRID_NOTIFY_LOG_NAME=log

# Generic JSON webhook. If secret is set, requests carry X-Ongrid-Signature.
ONGRID_NOTIFY_WEBHOOK_ENABLED=false
ONGRID_NOTIFY_WEBHOOK_NAME=webhook
ONGRID_NOTIFY_WEBHOOK_URL=
ONGRID_NOTIFY_WEBHOOK_SECRET=

# Slack incoming webhook.
ONGRID_NOTIFY_SLACK_ENABLED=false
ONGRID_NOTIFY_SLACK_NAME=slack
ONGRID_NOTIFY_SLACK_WEBHOOK_URL=

# Feishu/Lark custom bot webhook.
ONGRID_NOTIFY_FEISHU_ENABLED=false
ONGRID_NOTIFY_FEISHU_NAME=feishu
ONGRID_NOTIFY_FEISHU_WEBHOOK_URL=
ONGRID_NOTIFY_FEISHU_SECRET=

# DingTalk custom robot webhook.
ONGRID_NOTIFY_DINGTALK_ENABLED=false
ONGRID_NOTIFY_DINGTALK_NAME=dingtalk
ONGRID_NOTIFY_DINGTALK_WEBHOOK_URL=
ONGRID_NOTIFY_DINGTALK_SECRET=

# ongrid-edge only — dial the broker's edge-bound port (40012, host-mapped to 40012)
ONGRID_EDGE_CLOUD_ADDR=localhost:40012
ONGRID_EDGE_ACCESS_KEY=
ONGRID_EDGE_SECRET_KEY=
ONGRID_EDGE_COLLECTOR_MODE=auto
ONGRID_EDGE_SCRAPE_CONFIG_FILE=/etc/ongrid-edge/scrape.yaml
ONGRID_EDGE_COLLECTOR_INTERVAL=10s
